generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// CORE: Tablas compartidas por todas las unidades
// ==========================================

enum Unit {
  travel
  work_study
  oxford_education
}

enum Channel {
  whatsapp
  web
  instagram
}

enum ConversationStatus {
  active
  waiting_human
  closed
  follow_up
}

enum MessageDirection {
  inbound
  outbound
}

enum SenderType {
  user
  bot
  agent
}

enum ContentType {
  text
  image
  document
  audio
  template
  interactive
}

model Contact {
  id            String    @id @default(uuid())
  phone         String    @unique         // Número normalizado E.164
  name          String?
  email         String?
  sourceUnit    Unit      @map("source_unit")
  activeUnits   Unit[]    @map("active_units")
  tags          String[]  @default([])
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt      @map("updated_at")

  conversations Conversation[]
  travelLeads   TravelLead[]
  // workStudyLeads WorkStudyLead[]    // Fase 2
  // oxfordLeads    OxfordLead[]       // Fase 3

  @@map("contacts")
}

model Conversation {
  id             String             @id @default(uuid())
  contactId      String             @map("contact_id")
  unit           Unit
  channel        Channel            @default(whatsapp)
  status         ConversationStatus @default(active)
  assignedAgent  String?            @map("assigned_agent")
  interestScore  Int                @default(0) @map("interest_score")
  metadata       Json?              @default("{}")
  startedAt      DateTime           @default(now()) @map("started_at")
  lastMessageAt  DateTime           @default(now()) @map("last_message_at")
  closedAt       DateTime?          @map("closed_at")

  contact        Contact            @relation(fields: [contactId], references: [id])
  messages       Message[]

  @@index([contactId, unit])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String           @id @default(uuid())
  conversationId String           @map("conversation_id")
  direction      MessageDirection
  senderType     SenderType       @map("sender_type")
  contentType    ContentType      @default(text) @map("content_type")
  content        String
  mediaUrl       String?          @map("media_url")
  waMessageId    String?          @map("wa_message_id")
  createdAt      DateTime         @default(now()) @map("created_at")

  conversation   Conversation     @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([waMessageId])
  @@map("messages")
}

// ==========================================
// TRAVEL: Tablas específicas de Travel (Fase 1)
// ==========================================

enum TravelLeadStatus {
  nuevo
  contactado
  interesado
  materiales_enviados
  derivado_asesor
  en_proceso_pago
  inscrito
  no_interesado
}

model TravelLead {
  id              String            @id @default(uuid())
  contactId       String            @map("contact_id")
  tripId          String?           @map("trip_id")       // ID del viaje en Google Sheets
  schoolCode      String?           @map("school_code")   // Código del colegio
  programInterest String?           @map("program_interest")
  travelerName    String?           @map("traveler_name")
  travelerAge     Int?              @map("traveler_age")
  parentName      String?           @map("parent_name")
  budgetRange     String?           @map("budget_range")
  status          TravelLeadStatus  @default(nuevo)
  materialsSent   String[]          @default([]) @map("materials_sent")
  followUpDate    DateTime?         @map("follow_up_date")
  followUpCount   Int               @default(0) @map("follow_up_count")
  notes           String?
  extras          Json?             @default("{}") // Actividades extras, París, etc.
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt      @map("updated_at")

  contact         Contact           @relation(fields: [contactId], references: [id])

  @@index([contactId])
  @@index([status])
  @@index([schoolCode])
  @@map("travel_leads")
}

